# Copy to `.env` to override the defaults docker-compose.yml falls back to.
# None of these are required for a first `docker compose up` -- the compose
# file ships with working (dev-only) defaults for all of them.
#
# These are also exactly the values the `deploy` job in
# .github/workflows/cd.yml writes into `.env` from GitHub Actions secrets
# before running `docker compose up` on the runner host -- see that job and
# infra/github-runner/SETUP.md for the secrets that need to be configured
# on the repo for CD to work.

# Postgres password (user is always `dapp`, not worth a secret).
POSTGRES_PASSWORD=dapp

# Signs backend JWTs. Change this for anything beyond local testing.
JWT_SECRET=dev-only-change-me

# Which docker-compose profiles to activate. "local-chain" starts
# hardhat-node + the one-shot contract-deploy service, giving you a full
# local Hardhat chain with zero setup -- this is the default for local dev.
# Leave unset (or omit "local-chain") when pointing at a real network like
# Sepolia via RPC_URL/CONTRACT_ADDRESS below.
COMPOSE_PROFILES=local-chain

# RPC endpoint the backend reads/writes chain state through. Defaults to the
# local hardhat-node container. For Sepolia, set this to your RPC provider's
# HTTPS endpoint (e.g. Alchemy/Infura).
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-api-key>

# Deployed Marketplace contract address. Leave unset for local Hardhat (the
# address is instead read from the file the one-shot deploy service writes,
# via CONTRACT_ADDRESS_FILE). Required when RPC_URL points at Sepolia, since
# there's no local one-shot deploy step there -- run `npm run deploy:sepolia`
# in contracts/ once (see below) and paste the resulting address here.
# CONTRACT_ADDRESS=0x...

# Optional. nginx (frontend/nginx.conf) reverse-proxies /api/* to the
# backend container, so the frontend defaults to a same-origin relative
# path and this normally does NOT need to be set. Only set it if the
# frontend and backend are served from different origins.
# VITE_API_BASE_URL=http://your-backend-host:8090/api/v1

# --- Sepolia contract deployment (contracts/ only -- NOT read by
# docker-compose or the backend; used once via `npm run deploy:sepolia` in
# contracts/, then discarded). Never commit real values for these.
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-api-key>
# SEPOLIA_DEPLOYER_PRIVATE_KEY=0x... (a wallet funded with Sepolia test ETH,
#   e.g. from https://sepoliafaucet.com -- deployer only, not a user wallet)
